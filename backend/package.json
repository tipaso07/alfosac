{
  "name": "alfosac-backend",
  "version": "1.0.0",
  "description": "Backend para gestión de inventario",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$p=(Get-NetTCPConnection -LocalPort 5000 -ErrorAction SilentlyContinue).OwningProcess; if($p){Stop-Process -Id $p -Force -ErrorAction SilentlyContinue}; nodemon server.js\"",
    "db:migrate": "node run-migrations.js",
    "clean-test": "node clean-and-seed-test-data.js",
    "db:demo": "node prepare-demo-db.js",
    "db:empty": "node prepare-empty-db.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
